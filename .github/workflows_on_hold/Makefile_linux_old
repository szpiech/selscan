# Makefile for selscan (Linux) - single executable version

# Compiler
CXX ?= g++

# Base compile flags
BASE_CXXFLAGS = -O3 -m64 -mmmx -msse -msse2 -ftree-vectorize -fno-pie -std=c++17

# Base link flags
BASE_LDFLAGS = -no-pie

# User-overridable flags
CXXFLAGS ?=
LDFLAGS ?=
LDLIBS_EXTRA ?=

# Final flags
ALL_CXXFLAGS = $(BASE_CXXFLAGS) $(CXXFLAGS)
ALL_LDFLAGS = $(BASE_LDFLAGS) $(LDFLAGS)

# Include and library paths
I_PATH = -I../include
L_PATH = ../lib/linux

# Libraries
LDLIBS = -lm -pthread -lz -L$(L_PATH) -lgsl -lgslcblas $(LDLIBS_EXTRA)

# Object files
OBJ_STATS = xpihh.o ehh.o ihs.o ihh12.o pi.o ehh12.o
OBJ_HAPMAP = hapdata.o mapdata.o bitset.o
OBJS = selscan-main.o $(OBJ_STATS) selscan-data.o $(OBJ_HAPMAP) selscan-cli.o binom.o param_t.o norm.o gene.o gzstream.o thread_pool.o

# Default target
all: selscan

# Build selscan binary
selscan: $(OBJS)
	$(CXX) $(ALL_CXXFLAGS) $(ALL_LDFLAGS) -o $@ $^ $(LDLIBS)

# Compilation rules
selscan-main.o: selscan-main.cpp
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

selscan-data.o: selscan-data.cpp selscan-data.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

selscan-cli.o: selscan-cli.cpp selscan-cli.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

binom.o: binom.cpp binom.h
	$(CXX) $(ALL_CXXFLAGS) -c $< -o $@

norm.o: norm.cpp norm.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

gene.o: gene.cpp gene.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

param_t.o: param_t.cpp param_t.h
	$(CXX) $(ALL_CXXFLAGS) -c $< -o $@

gzstream.o: gzstream.cpp gzstream.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

thread_pool.o: thread_pool.cpp thread_pool.h
	$(CXX) $(ALL_CXXFLAGS) -c $< -o $@

# Pattern rules
%.o: hapmap/%.cpp hapmap/%.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

%.o: stats/%.cpp stats/%.h
	$(CXX) $(ALL_CXXFLAGS) $(I_PATH) -c $< -o $@

# Cleanup
clean:
	rm -rf *.o selscan